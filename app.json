{
  "expo": {
    "name": "MatchPulse",
    "slug": "matchpulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "matchpulse",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f8fb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matchpulse.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "MatchPulse cần quyền truy cập ảnh để cập nhật ảnh đại diện."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f7f8fb"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.matchpulse.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f7f8fb"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#14b8a6",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MatchPulse cần quyền truy cập ảnh để cập nhật ảnh đại diện."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f4e6ee46-b773-4bd7-b01b-1d1abbf0cd65"
      }
    }
  }
}
